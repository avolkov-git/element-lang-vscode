{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([A-Za-zА-Яа-я_][A-Za-zА-Яа-я0-9_]*)",
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:Если.+Тогда|ИначеЕсли.+Тогда|Для.+Цикл|Для\\s+Каждого.+Цикл|Пока.+Цикл|Попытка|Процедура\\b.*|Функция\\b.*)\\s*$",
    "decreaseIndentPattern": "^\\s*(?:Иначе|ИначеЕсли.+Тогда|КонецЕсли|КонецЦикла|Исключение|КонецПопытки|КонецПроцедуры|КонецФункции)\\b.*$"
  },
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#region\\b",
      "end": "^\\s*//\\s*#endregion\\b"
    }
  }
}
