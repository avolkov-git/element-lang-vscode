Перем Имя;

// #region demo
Функция Приветствие(Знач ИмяПользователя) Экспорт
  Возврат "Привет, " + ИмяПользователя;
КонецФункции

Процедура Выполнить()
  Имя = "Александр";

  Если Имя <> "" Тогда
    Сообщить(Приветствие(Имя));
  Иначе
    Сообщить("Имя не задано");
  КонецЕсли;
КонецПроцедуры

Попытка
  Выполнить();
Исключение
  Сообщить("Ошибка выполнения");
КонецПопытки
}
// #endregion demo
