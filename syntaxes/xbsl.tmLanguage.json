{
  "name": "XBSL",
  "scopeName": "source.xbsl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#query-block"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#typed-literals"
    },
    {
      "include": "#duration-literals"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#method-declarations"
    },
    {
      "include": "#type-declarations"
    },
    {
      "include": "#constant-declarations"
    },
    {
      "include": "#variable-declarations"
    },
    {
      "include": "#type-contexts"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xbsl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.xbsl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "query-block": {
      "patterns": [
        {
          "name": "meta.embedded.block.query.xbsl",
          "begin": "\\b(Запрос)(\\s*)(\\{)",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.query.literal.xbsl"
            },
            "3": {
              "name": "punctuation.section.group.xbsl"
            }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.group.xbsl"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "variable.parameter.query.xbql",
              "match": "%(?:\\{[^}]+\\}|[\\p{L}_][\\p{L}\\p{N}_.]*)"
            },
            {
              "name": "support.function.aggregate.xbql",
              "match": "\\b(КОЛИЧЕСТВО|СУММА|МАКСИМУМ|МИНИМУМ|СРЕДНЕЕ)\\b"
            },
            {
              "name": "keyword.control.query.xbql",
              "match": "\\b(ВЫБРАТЬ|ИЗ|ГДЕ|КАК|МЕЖДУ|И|ИЛИ|НЕ|ПО|УПОРЯДОЧИТЬ|ВОЗР|УБЫВ|СГРУППИРОВАТЬ|ИМЕЮЩИЕ|ОБЪЕДИНИТЬ|ВСЕ|ПЕРВЫЕ|РАЗЛИЧНЫЕ|ЛЕВОЕ|ПРАВОЕ|ВНУТРЕННЕЕ|СОЕДИНЕНИЕ)\\b"
            },
            {
              "match": "\\b([\\p{Lu}][\\p{L}\\p{N}_]*(?:\\.[\\p{Lu}][\\p{L}\\p{N}_]*)*)(\\.)([\\p{Lu}][\\p{L}\\p{N}_]*)\\b",
              "captures": {
                "1": {
                  "name": "entity.name.query.xbql"
                }
              }
            },
            {
              "name": "entity.name.query.xbql",
              "match": "\\b[\\p{Lu}][\\p{L}\\p{N}_]*\\b"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xbsl",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.xbsl"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.xbsl"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.xbsl",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.xbsl",
              "match": "(?:%|\\$)(?:\\{[^}]+\\}|[\\p{L}_][\\p{L}\\p{N}_.]*)"
            }
          ]
        }
      ]
    },
    "typed-literals": {
      "patterns": [
        {
          "name": "meta.literal.typed.xbsl",
          "match": "\\b(Ресурс|Байты|Версия|Время|Дата|ДатаВремя|Длительность|Момент|Тип|Ууид)(\\{)([^}]*)(\\})",
          "captures": {
            "1": {
              "name": "support.type.literal.xbsl"
            },
            "2": {
              "name": "punctuation.section.group.xbsl"
            },
            "3": {
              "name": "string.unquoted.literal.xbsl"
            },
            "4": {
              "name": "punctuation.section.group.xbsl"
            }
          }
        }
      ]
    },
    "duration-literals": {
      "patterns": [
        {
          "name": "constant.numeric.duration.xbsl",
          "match": "(?<![\\p{L}\\p{N}_])(?:[+-])?(?=(?:\\d+д|\\d+ч|\\d+м(?!с)|\\d+с|\\d+мс))(?:\\d+д)?(?:\\d+ч)?(?:\\d+м(?!с))?(?:\\d+с)?(?:\\d+мс)?(?![\\p{L}\\p{N}_])"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.annotation.xbsl",
          "match": "@[\\p{L}_][\\p{L}\\p{N}_]*"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.xbsl",
          "match": "\\b(импорт)\\b\\s+((?:[\\p{L}_][\\p{L}\\p{N}_]*)(?:::(?:[\\p{L}_][\\p{L}\\p{N}_]*))*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.xbsl"
            },
            "2": {
              "name": "entity.name.namespace.xbsl"
            }
          }
        }
      ]
    },
    "statement-patterns": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#query-block"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#typed-literals"
        },
        {
          "include": "#duration-literals"
        },
        {
          "include": "#annotations"
        },
        {
          "include": "#constant-declarations"
        },
        {
          "include": "#variable-declarations"
        },
        {
          "include": "#type-contexts"
        },
        {
          "include": "#builtin-types"
        },
        {
          "include": "#constants"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#punctuation"
        }
      ]
    },
    "type-patterns": {
      "patterns": [
        {
          "name": "keyword.operator.xbsl",
          "match": "(\\|)"
        },
        {
          "name": "keyword.operator.xbsl",
          "match": "(->)"
        },
        {
          "name": "keyword.operator.xbsl",
          "match": "(\\?)"
        },
        {
          "name": "support.type.xbsl",
          "match": "\\b(Авто|ничто|[\\p{L}_][\\p{L}\\p{N}_]*)(?:(?:::|\\.)[\\p{L}_][\\p{L}\\p{N}_]*)*\\b"
        }
      ]
    },
    "compound-type": {
      "begin": "(?<!:)(:)(?!:)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.separator.type.xbsl"
        }
      },
      "end": "(?=\\s*(?:=|,|\\)|$))",
      "patterns": [
        {
          "include": "#type-patterns"
        }
      ]
    },
    "compound-type-with-bracket": {
      "begin": "(?<!:)(:)\\s*\\(",
      "beginCaptures": {
        "1": {
          "name": "punctuation.separator.type.xbsl"
        }
      },
      "end": "(?=\\s*(?:=|,|$))",
      "patterns": [
        {
          "name": "punctuation.section.group.xbsl",
          "match": "[()]"
        },
        {
          "include": "#type-patterns"
        }
      ]
    },
    "method-declarations": {
      "patterns": [
        {
          "name": "meta.function.xbsl",
          "begin": "\\b(абстрактный)\\b\\s+(?:(статический)\\b\\s+)?(метод)\\b\\s+([\\p{L}_][\\p{L}\\p{N}_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.xbsl"
            },
            "2": {
              "name": "storage.modifier.xbsl"
            },
            "3": {
              "name": "keyword.declaration.method.xbsl"
            },
            "4": {
              "name": "entity.name.function.xbsl"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#compound-type-with-bracket"
            },
            {
              "include": "#compound-type"
            },
            {
              "include": "#statement-patterns"
            }
          ]
        },
        {
          "name": "meta.function.xbsl",
          "begin": "\\b(?:(статический)\\b\\s+)?(метод)\\b\\s+([\\p{L}_][\\p{L}\\p{N}_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "storage.modifier.xbsl"
            },
            "2": {
              "name": "keyword.declaration.method.xbsl"
            },
            "3": {
              "name": "entity.name.function.xbsl"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#compound-type-with-bracket"
            },
            {
              "include": "#compound-type"
            },
            {
              "include": "#statement-patterns"
            }
          ]
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.exception.definition.xbsl",
          "match": "\\b(исключение)\\b\\s+([\\p{L}_][\\p{L}\\p{N}_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.xbsl"
            },
            "2": {
              "name": "entity.name.type.xbsl"
            }
          }
        },
        {
          "name": "meta.type.definition.xbsl",
          "match": "\\b(структура|перечисление|контракт)\\b\\s+([\\p{L}_][\\p{L}\\p{N}_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.xbsl"
            },
            "2": {
              "name": "entity.name.type.xbsl"
            }
          }
        }
      ]
    },
    "constant-declarations": {
      "patterns": [
        {
          "name": "meta.constant.definition.xbsl",
          "begin": "\\b(конст)\\b\\s+([A-ZА-ЯЁ][A-ZА-ЯЁ0-9_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "storage.modifier.constant.xbsl"
            },
            "2": {
              "name": "variable.other.definition.xbsl"
            }
          },
          "end": "(?=\\s*(?:=|$))",
          "patterns": [
            {
              "include": "#compound-type-with-bracket"
            },
            {
              "include": "#compound-type"
            }
          ]
        }
      ]
    },
    "variable-declarations": {
      "patterns": [
        {
          "name": "meta.variable.definition.xbsl",
          "begin": "\\b((?:(?:обз|пер|знч|исп)\\b\\s+)+)([\\p{L}_][\\p{L}\\p{N}_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "storage.modifier.xbsl"
            },
            "2": {
              "name": "variable.other.definition.xbsl"
            }
          },
          "end": "(?=\\s*(?:=|,|\\)|/|$))",
          "patterns": [
            {
              "include": "#compound-type-with-bracket"
            },
            {
              "include": "#compound-type"
            }
          ]
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.xbsl",
          "match": "\\b(ничто|неизвестно|никогда)\\b"
        }
      ]
    },
    "type-contexts": {
      "patterns": [
        {
          "name": "meta.type.instantiation.xbsl",
          "begin": "\\b(новый)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.xbsl"
            }
          },
          "end": "(?=\\()",
          "patterns": [
            {
              "include": "#type-patterns"
            }
          ]
        },
        {
          "name": "meta.type.check.xbsl",
          "begin": "\\b(как|это)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.xbsl"
            }
          },
          "end": "(?=\\s*(?:,|\\)|\\}|;|$))",
          "patterns": [
            {
              "include": "#type-patterns"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xbsl",
          "match": "\\b(абстрактный|импорт|иначе\\s+если|если|иначе|пока|для|по|из|до|попытка|поймать|выбросить|возврат|не|и|или|как|это|этот|когда|выбор)\\b"
        },
        {
          "name": "storage.modifier.xbsl",
          "match": "\\b(пер|знч|обз|исп|конст|статический)\\b"
        },
        {
          "name": "keyword.declaration.xbsl",
          "match": "\\b(метод|структура|перечисление|контракт|исключение)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.xbsl",
          "match": "\\b(Истина|Ложь)\\b"
        },
        {
          "name": "constant.language.xbsl",
          "match": "\\b(Неопределено)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.xbsl",
          "match": "\\b\\d+(?:_\\d+)*(?:\\.\\d+(?:_\\d+)*)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.xbsl",
          "match": "(?:==|!=|<=|>=|->|=>|[+\\-*/%=<>]+|\\?|:)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.group.xbsl",
          "match": "[()\\[\\]{}]"
        },
        {
          "name": "punctuation.terminator.statement.xbsl",
          "match": ";"
        }
      ]
    }
  }
}
