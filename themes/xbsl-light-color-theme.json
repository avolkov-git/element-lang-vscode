{
  "name": "XBSL Light",
  "type": "light",
  "semanticHighlighting": false,
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#111111"
  },
  "tokenColors": [
    {
      "scope": [
        "comment.line.double-slash.xbsl",
        "comment.block.xbsl"
      ],
      "settings": {
        "foreground": "#0B8F14"
      }
    },
    {
      "scope": [
        "keyword.codetag.todo.xbsl"
      ],
      "settings": {
        "foreground": "#1838FF"
      }
    },
    {
      "scope": [
        "entity.name.annotation.xbsl"
      ],
      "settings": {
        "foreground": "#C400FF"
      }
    },
    {
      "scope": [
        "keyword.control.xbsl",
        "keyword.control.import.xbsl",
        "support.type.literal.xbsl"
      ],
      "settings": {
        "foreground": "#C400FF"
      }
    },
    {
      "scope": [
        "storage.modifier.xbsl",
        "storage.modifier.constant.xbsl",
        "keyword.declaration.method.xbsl",
        "keyword.declaration.type.xbsl",
        "keyword.declaration.xbsl",
        "keyword.control.query.xbql",
        "keyword.other.query.literal.xbsl"
      ],
      "settings": {
        "foreground": "#1838FF"
      }
    },
    {
      "scope": [
        "variable.other.definition.xbsl"
      ],
      "settings": {
        "foreground": "#001080"
      }
    },
    {
      "scope": [
        "constant.language.xbsl"
      ],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "scope": [
        "constant.language.boolean.xbsl"
      ],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "scope": [
        "entity.name.function.xbsl",
        "support.function.aggregate.xbql"
      ],
      "settings": {
        "foreground": "#8C6B2E"
      }
    },
    {
      "scope": [
        "support.type.xbsl",
        "entity.name.namespace.xbsl",
        "entity.name.type.xbsl",
        "entity.name.query.xbql"
      ],
      "settings": {
        "foreground": "#2E8DB5"
      }
    },
    {
      "scope": [
        "string.quoted.single.xbsl",
        "string.quoted.double.xbsl"
      ],
      "settings": {
        "foreground": "#C11F16"
      }
    },
    {
      "scope": [
        "variable.interpolation.xbsl",
        "variable.parameter.query.xbql"
      ],
      "settings": {
        "foreground": "#1B2FAD"
      }
    },
    {
      "scope": [
        "constant.numeric.xbsl"
      ],
      "settings": {
        "foreground": "#138A3B"
      }
    },
    {
      "scope": [
        "constant.numeric.duration.xbsl"
      ],
      "settings": {
        "foreground": "#0B8658"
      }
    },
    {
      "scope": [
        "punctuation.section.group.xbsl"
      ],
      "settings": {
        "foreground": "#315BFF"
      }
    },
    {
      "scope": [
        "punctuation.terminator.statement.xbsl"
      ],
      "settings": {
        "foreground": "#1838FF"
      }
    }
  ]
}
